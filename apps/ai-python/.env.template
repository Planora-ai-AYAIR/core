# GeoSense Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# =====================================================
# Google Earth Engine Configuration
# =====================================================

# GEE Project ID
# Get from: https://console.cloud.google.com
GEE_PROJECT=planora-497015

# Service Account Email
# Get from: GCP Console > Service Accounts > [Your Service Account]
GEE_SERVICE_ACCOUNT_EMAIL=planora@planora-497015.iam.gserviceaccount.com

# Service Account Key File Path
# Download JSON key from GCP Console and update path
GEE_SERVICE_ACCOUNT_KEY=./secrets/planora_gee.json

# =====================================================
# Redis Configuration (Job Cache)
# =====================================================

# Redis connection URL
# Format: redis://[user:password@]host[:port][/db]
REDIS_URL=redis://localhost:6379

# =====================================================
# Output Configuration
# =====================================================

# Local directory for temporary files
LOCAL_OUT_DIR=/tmp/geosense

# =====================================================
# Egypt Boundary (EPSG:4326)
# =====================================================

# Egypt bounds: [minLon, minLat, maxLon, maxLat]
# Must be a JSON array — config.py types this as list[float] (pydantic-settings)
# Current value: 24°E to 37°E, 22°N to 32°N
EGYPT_BBOX=[24.0, 22.0, 37.0, 32.0]

# =====================================================
# API Configuration
# =====================================================

# API title for Swagger documentation
API_TITLE=GeoSense API

# API version
API_VERSION=0.1.0

# =====================================================
# Topography / Terrain Data (router reads these via os.getenv)
# =====================================================
# NOTE: These are NOT parsed from .env — config.py's pydantic Settings
# forbids extra keys. The router reads them from the real process
# environment (os.getenv), so set them as OS/Docker env vars to override.
# Defaults if unset:
#   RASTER_DIR=/data/rasters/
#   MODEL_B_PATH=/data/models/model_b_bundle.joblib


